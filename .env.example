# YuGAgent Environment Configuration
# Copy this file to .env and fill in your values

# Zhipu AI Configuration
# Get your API key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_api_key_here

# Optional: Custom model (default: glm-4.7)
# ZHIPU_MODEL=glm-4.7

# Optional: Custom base URL (default: https://open.bigmodel.cn/api/paas/v4)
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Optional: Request timeout in milliseconds (default: 60000)
# ZHIPU_TIMEOUT=60000

# Optional: Maximum retries for failed requests (default: 3)
# ZHIPU_MAX_RETRIES=3
